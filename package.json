{
  "name": "@torency/ask-widget",
  "version": "0.1.2",
  "description": "Embeddable React Ask widget for Archeo/memory backends.",
  "type": "module",
  "main": "./dist/torency-ask-widget.umd.cjs",
  "module": "./dist/torency-ask-widget.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/torency-ask-widget.js",
      "require": "./dist/torency-ask-widget.umd.cjs"
    },
    "./styles.css": "./dist/torency-ask-widget.css"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && vite build",
    "check": "tsc -p tsconfig.json --noEmit",
    "prepack": "npm run build",
    "prepare": "npm run build"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.5.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
